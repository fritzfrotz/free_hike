node_modules/
.expo/
ios/Pods/
android/app/build/

# Nested sandbox repositories (vendored checkouts, never part of this repo)
offline_sandbox/gdal/
offline_sandbox/massif/

# Sandbox pipeline outputs — regenerable via scripts/compile_sandbox_data.sh
offline_sandbox/output/

