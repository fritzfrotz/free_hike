{
  "name": "freehike",
  "private": true,
  "version": "0.1.0",
  "description": "Zero-cost offline hiking maps: the phone downloads raw OpenStreetMap + DEM data and compiles its own vector basemap, terrain, and routing \u2014 no servers, ever.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/freehike/freehike.git"
  },
  "type": "module",
  "scripts": {
    "predev": "node scripts/copy_valhalla_wasm.mjs",
    "dev": "vite",
    "prebuild": "node scripts/copy_valhalla_wasm.mjs",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "build:graph": "node scripts/build_test_graph.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@capacitor-community/background-geolocation": "^1.2.26",
    "@capacitor/android": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/ios": "^8.4.1",
    "@jansoft/mbujkanji-valhalla-wasm": "^0.1.2",
    "flatbush": "^4.6.2",
    "flatgeobuf": "^4.4.0",
    "maplibre-contour": "^0.1.0",
    "maplibre-gl": "^5.24.0",
    "pmtiles": "^4.4.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "4.1.9"
  }
}