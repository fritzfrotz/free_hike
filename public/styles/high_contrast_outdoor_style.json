{
  "version": 8,
  "name": "High-Contrast Offline Alpine Style",
  "metadata": {
    "maplibre:autocompound": true
  },
  "center": [11.3908, 47.2757],
  "zoom": 12,
  "pitch": 40,
  "bearing": 0,
  "sources": {
    "basemap-local": {
      "type": "vector",
      "url": "pmtiles://local/alps_basemap.pmtiles",
      "attribution": "© OpenStreetMap contributors"
    },
    "terrain-local": {
      "type": "raster-dem",
      "url": "pmtiles://local/alps_terrain.pmtiles",
      "encoding": "mapbox",
      "tileSize": 512
    }
  },
  "glyphs": "/glyphs/{fontstack}/{range}.pbf",
  "sprite": "/sprites/outdoor",
  "terrain": {
    "source": "terrain-local",
    "exaggeration": 1.3
  },
  "layers": [
    {
      "id": "background-layer",
      "type": "background",
      "paint": {
        "background-color": "#E5E5E5"
      }
    },
    {
      "id": "landuse-forest",
      "type": "fill",
      "source": "basemap-local",
      "source-layer": "landuse",
      "minzoom": 4,
      "filter": ["match", ["get", "class"], ["forest", "wood"], true, false],
      "paint": {
        "fill-color": "#1B4D3E",
        "fill-opacity": 1.0
      }
    },
    {
      "id": "landuse-vegetation",
      "type": "fill",
      "source": "basemap-local",
      "source-layer": "landuse",
      "minzoom": 4,
      "filter": ["match", ["get", "class"], ["grass", "meadow", "scrub", "farmland", "orchard", "vineyard"], true, false],
      "paint": {
        "fill-color": "#A3B899",
        "fill-opacity": 1.0
      }
    },
    {
      "id": "landuse-other",
      "type": "fill",
      "source": "basemap-local",
      "source-layer": "landuse",
      "minzoom": 6,
      "filter": ["!", ["match", ["get", "class"], ["forest", "wood", "grass", "meadow", "scrub", "farmland", "orchard", "vineyard"], true, false]],
      "paint": {
        "fill-color": "#D8CFC0",
        "fill-opacity": 0.8
      }
    },
    {
      "id": "natural-wood",
      "type": "fill",
      "source": "basemap-local",
      "source-layer": "natural",
      "minzoom": 4,
      "filter": ["==", ["get", "class"], "wood"],
      "paint": {
        "fill-color": "#1B4D3E",
        "fill-opacity": 1.0
      }
    },
    {
      "id": "natural-vegetation",
      "type": "fill",
      "source": "basemap-local",
      "source-layer": "natural",
      "minzoom": 4,
      "filter": ["match", ["get", "class"], ["scrub", "grassland", "heath"], true, false],
      "paint": {
        "fill-color": "#A3B899",
        "fill-opacity": 1.0
      }
    },
    {
      "id": "natural-water",
      "type": "fill",
      "source": "basemap-local",
      "source-layer": "natural",
      "minzoom": 4,
      "filter": ["match", ["get", "class"], ["water", "wetland"], true, false],
      "paint": {
        "fill-color": "#005F73",
        "fill-opacity": 1.0
      }
    },
    {
      "id": "natural-glacier",
      "type": "fill",
      "source": "basemap-local",
      "source-layer": "natural",
      "minzoom": 4,
      "filter": ["==", ["get", "class"], "glacier"],
      "paint": {
        "fill-color": "#DCEEF2",
        "fill-opacity": 1.0
      }
    },
    {
      "id": "natural-rock",
      "type": "fill",
      "source": "basemap-local",
      "source-layer": "natural",
      "minzoom": 6,
      "filter": ["match", ["get", "class"], ["bare_rock", "scree", "cliff", "shingle"], true, false],
      "paint": {
        "fill-color": "#D3D3D3",
        "fill-opacity": 1.0
      }
    },
    {
      "id": "dynamic-hillshading",
      "type": "hillshade",
      "source": "terrain-local",
      "paint": {
        "hillshade-illumination-direction": 315,
        "hillshade-illumination-anchor": "map",
        "hillshade-exaggeration": 0.5,
        "hillshade-shadow-color": "#131E29",
        "hillshade-highlight-color": "#FFFFFF",
        "hillshade-accent-color": "#4A1525"
      }
    },
    {
      "id": "waterway-major",
      "type": "line",
      "source": "basemap-local",
      "source-layer": "waterway",
      "minzoom": 7,
      "filter": ["==", ["get", "class"], "river"],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#0A84A8",
        "line-width": ["interpolate", ["linear"], ["zoom"], 7, 0.8, 12, 2.5, 18, 6.0]
      }
    },
    {
      "id": "waterway-minor",
      "type": "line",
      "source": "basemap-local",
      "source-layer": "waterway",
      "minzoom": 9,
      "filter": ["!", ["==", ["get", "class"], "river"]],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#0A84A8",
        "line-width": ["interpolate", ["linear"], ["zoom"], 9, 0.5, 14, 1.5, 18, 3.0]
      }
    },
    {
      "id": "trail-path",
      "type": "line",
      "source": "basemap-local",
      "source-layer": "highway",
      "minzoom": 10,
      "filter": ["match", ["get", "class"], ["path", "footway"], true, false],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": [
          "match", ["get", "sac_scale"],
          "mountain_hiking", "#F1C40F",
          "demanding_mountain_hiking", "#E74C3C",
          "alpine_hiking", "#000000",
          "demanding_alpine_hiking", "#000000",
          "difficult_alpine_hiking", "#000000",
          "#2ECC71"
        ],
        "line-width": ["interpolate", ["linear"], ["zoom"], 12, 1.5, 15, 3.5, 18, 5.0]
      }
    },
    {
      "id": "trail-track",
      "type": "line",
      "source": "basemap-local",
      "source-layer": "highway",
      "minzoom": 10,
      "filter": ["==", ["get", "class"], "track"],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": [
          "match", ["get", "sac_scale"],
          "mountain_hiking", "#F1C40F",
          "demanding_mountain_hiking", "#E74C3C",
          "alpine_hiking", "#000000",
          "demanding_alpine_hiking", "#000000",
          "difficult_alpine_hiking", "#000000",
          "#2ECC71"
        ],
        "line-width": ["interpolate", ["linear"], ["zoom"], 12, 1.5, 15, 3.5, 18, 5.0],
        "line-dasharray": [4, 2]
      }
    },
    {
      "id": "trail-bridleway",
      "type": "line",
      "source": "basemap-local",
      "source-layer": "highway",
      "minzoom": 10,
      "filter": ["==", ["get", "class"], "bridleway"],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": [
          "match", ["get", "sac_scale"],
          "mountain_hiking", "#F1C40F",
          "demanding_mountain_hiking", "#E74C3C",
          "alpine_hiking", "#000000",
          "demanding_alpine_hiking", "#000000",
          "difficult_alpine_hiking", "#000000",
          "#2ECC71"
        ],
        "line-width": ["interpolate", ["linear"], ["zoom"], 12, 1.5, 15, 3.0, 18, 4.5],
        "line-dasharray": [1, 2]
      }
    },
    {
      "id": "trail-steps",
      "type": "line",
      "source": "basemap-local",
      "source-layer": "highway",
      "minzoom": 12,
      "filter": ["==", ["get", "class"], "steps"],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": [
          "match", ["get", "sac_scale"],
          "mountain_hiking", "#F1C40F",
          "demanding_mountain_hiking", "#E74C3C",
          "alpine_hiking", "#000000",
          "demanding_alpine_hiking", "#000000",
          "difficult_alpine_hiking", "#000000",
          "#2ECC71"
        ],
        "line-width": ["interpolate", ["linear"], ["zoom"], 12, 1.5, 15, 3.5, 18, 5.5],
        "line-dasharray": [1, 1]
      }
    },
    {
      "id": "trail-cycleway",
      "type": "line",
      "source": "basemap-local",
      "source-layer": "highway",
      "minzoom": 10,
      "filter": ["==", ["get", "class"], "cycleway"],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": [
          "match", ["get", "sac_scale"],
          "mountain_hiking", "#F1C40F",
          "demanding_mountain_hiking", "#E74C3C",
          "alpine_hiking", "#000000",
          "demanding_alpine_hiking", "#000000",
          "difficult_alpine_hiking", "#000000",
          "#2ECC71"
        ],
        "line-width": ["interpolate", ["linear"], ["zoom"], 12, 1.5, 15, 3.0, 18, 4.5],
        "line-dasharray": [6, 2]
      }
    },
    {
      "id": "roads-other",
      "type": "line",
      "source": "basemap-local",
      "source-layer": "highway",
      "minzoom": 9,
      "filter": ["!", ["match", ["get", "class"], ["path", "footway", "track", "bridleway", "steps", "cycleway"], true, false]],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#7A7A7A",
        "line-width": ["interpolate", ["linear"], ["zoom"], 9, 0.5, 14, 2.0, 18, 4.0]
      }
    },
    {
      "id": "natural-peak",
      "type": "circle",
      "source": "basemap-local",
      "source-layer": "natural",
      "minzoom": 10,
      "filter": ["==", ["get", "class"], "peak"],
      "paint": {
        "circle-radius": 4,
        "circle-color": "#2B2D42",
        "circle-stroke-color": "#FFFFFF",
        "circle-stroke-width": 1.5
      }
    },
    {
      "id": "waterway-labels",
      "type": "symbol",
      "source": "basemap-local",
      "source-layer": "waterway",
      "minzoom": 12,
      "filter": ["has", "name"],
      "layout": {
        "symbol-placement": "line",
        "text-field": ["get", "name"],
        "text-font": ["Noto Sans Regular"],
        "text-size": 12
      },
      "paint": {
        "text-color": "#0A84A8",
        "text-halo-color": "#FFFFFF",
        "text-halo-width": 1
      }
    },
    {
      "id": "highway-labels",
      "type": "symbol",
      "source": "basemap-local",
      "source-layer": "highway",
      "minzoom": 14,
      "filter": ["has", "name"],
      "layout": {
        "symbol-placement": "line",
        "text-field": ["get", "name"],
        "text-font": ["Noto Sans Regular"],
        "text-size": 12
      },
      "paint": {
        "text-color": "#4A4A4A",
        "text-halo-color": "#FFFFFF",
        "text-halo-width": 1
      }
    },
    {
      "id": "natural-peak-label",
      "type": "symbol",
      "source": "basemap-local",
      "source-layer": "natural",
      "minzoom": 10,
      "filter": ["all", ["==", ["get", "class"], "peak"], ["has", "name"]],
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["Noto Sans Regular"],
        "text-size": 12,
        "text-offset": [0, 1],
        "text-anchor": "top"
      },
      "paint": {
        "text-color": "#000000",
        "text-halo-color": "#FFFFFF",
        "text-halo-width": 1
      }
    }
  ]
}
