{
  "version": 8,
  "name": "High-Contrast Offline Alpine Style",
  "metadata": {
    "maplibre:autocompound": true
  },
  "center": [11.3908, 47.2757],
  "zoom": 12,
  "pitch": 40,
  "bearing": 0,
  "sources": {
    "basemap-local": {
      "type": "vector",
      "url": "pmtiles://local/alps_basemap.pmtiles"
    },
    "terrain-local": {
      "type": "raster-dem",
      "url": "pmtiles://local/alps_terrain.pmtiles",
      "encoding": "mapbox",
      "tileSize": 512
    }
  },
  "terrain": {
    "source": "terrain-local",
    "exaggeration": 1.3
  },
  "layers": [
    {
      "id": "background-layer",
      "type": "background",
      "paint": {
        "background-color": "#E5E5E5"
      }
    },
    {
      "id": "forest-cover",
      "type": "fill",
      "source": "basemap-local",
      "source-layer": "landuse",
      "filter": ["==", ["get", "class"], "forest"],
      "paint": {
        "fill-color": "#1B4D3E",
        "fill-opacity": 1.0
      }
    },
    {
      "id": "meadow-scrub",
      "type": "fill",
      "source": "basemap-local",
      "source-layer": "landuse",
      "filter": ["match", ["get", "class"], ["scrub", "grass"], true, false],
      "paint": {
        "fill-color": "#A3B899",
        "fill-opacity": 1.0
      }
    },
    {
      "id": "barren-rock",
      "type": "fill",
      "source": "basemap-local",
      "source-layer": "natural",
      "filter": ["==", ["get", "class"], "rock"],
      "paint": {
        "fill-color": "#D3D3D3",
        "fill-opacity": 1.0
      }
    },
    {
      "id": "water-bodies",
      "type": "fill",
      "source": "basemap-local",
      "source-layer": "water",
      "paint": {
        "fill-color": "#005F73",
        "fill-opacity": 1.0
      }
    },
    {
      "id": "dynamic-hillshading",
      "type": "hillshade",
      "source": "terrain-local",
      "paint": {
        "hillshade-illumination-direction": 315,
        "hillshade-illumination-anchor": "map",
        "hillshade-exaggeration": 0.5,
        "hillshade-shadow-color": "#131E29",
        "hillshade-highlight-color": "#FFFFFF",
        "hillshade-accent-color": "#4A1525"
      }
    },
    {
      "id": "contours-line",
      "type": "line",
      "source": "basemap-local",
      "source-layer": "contours",
      "minzoom": 12.0,
      "paint": {
        "line-color": "#5C5C5C",
        "line-width": 0.8,
        "line-opacity": [
          "interpolate",
          ["linear"],
          ["zoom"],
          12.0, 0.0,
          13.0, 0.6
        ]
      }
    },
    {
      "id": "contours-labels",
      "type": "symbol",
      "source": "basemap-local",
      "source-layer": "contours",
      "minzoom": 13.5,
      "layout": {
        "symbol-placement": "line",
        "text-field": ["concat", ["to-string", ["get", "ele"]], " m"],
        "text-size": 9,
        "text-keep-upright": true,
        "text-rotation-alignment": "viewport-glyph"
      },
      "paint": {
        "text-color": "#2B2D42",
        "text-halo-color": "#FFFFFF",
        "text-halo-width": 2.0,
        "text-halo-blur": 0.5
      }
    },
    {
      "id": "dynamic-hiking-trails",
      "type": "line",
      "source": "basemap-local",
      "source-layer": "roads",
      "filter": ["==", ["geometry-type"], "LineString"],
      "paint": {
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          12, 1.5,
          15, 3.5,
          18, 5.0
        ],
        "line-color": [
          "match",
          ["coalesce", ["get", "sac_scale"], "hiking"],
          "strolling", "#2ECC71",
          "hiking", "#2ECC71",
          "mountain_hiking", "#3498DB",
          "demanding_mountain_hiking", "#F39C12",
          "alpine_hiking", "#E67E22",
          "demanding_alpine_hiking", "#E74C3C",
          "#2ECC71"
        ],
        "line-dasharray": [
          "match",
          ["coalesce", ["get", "sac_scale"], "hiking"],
          "strolling", ["literal", [1, 0]],
          "hiking", ["literal", [1, 0]],
          "mountain_hiking", ["literal", [8, 3]],
          "demanding_mountain_hiking", ["literal", [6, 4]],
          "alpine_hiking", ["literal", [3, 3]],
          "demanding_alpine_hiking", ["literal", [1, 3]],
          ["literal", [1, 0]]
        ]
      }
    },
    {
      "id": "peak-labels",
      "type": "symbol",
      "source": "basemap-local",
      "source-layer": "pois",
      "filter": ["==", ["get", "class"], "peak"],
      "layout": {
        "text-field": ["get", "name"],
        "text-size": [
          "interpolate",
          ["linear"],
          ["zoom"],
          10, 10,
          15, 14
        ],
        "text-variable-anchor": ["top", "bottom", "left", "right"],
        "text-radial-offset": 0.8
      },
      "paint": {
        "text-color": "#2B2D42",
        "text-halo-color": "#FFFFFF",
        "text-halo-width": 2.5,
        "text-halo-blur": 0.5
      }
    }
  ]
}
